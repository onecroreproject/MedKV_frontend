# Environment Configuration Template for Frontend
# Copy this to .env and fill in the values for your production environment

# Backend Base URL (Used for fetching static assets/uploads)
VITE_BASE_URL=https://api.yourdomain.com

# Backend API URL (Used for API calls)
VITE_API_URL=https://api.yourdomain.com/api/v1

# Payment Gateway Keys
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
